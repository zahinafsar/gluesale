// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Brand {
  id               String     @id @default(cuid())
  shop             String     @unique
  programActive    Boolean    @default(true)
  refereePercent   Int        @default(10)
  refereeMaxUses   Int        @default(1)
  refereeMinSpend  Int        @default(0)
  refererPercent   Int        @default(10)
  rewardExpiryDays Int        @default(30)
  fromEmail        String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  referrers        Referrer[]
  referrals        Referral[]
}

model Referrer {
  id                String     @id @default(cuid())
  brandId           String
  brand             Brand      @relation(fields: [brandId], references: [id], onDelete: Cascade)
  shopifyCustomerId String?
  email             String
  code              String     @unique
  firstOrderId      String?
  createdAt         DateTime   @default(now())
  referrals         Referral[]
  rewards           Reward[]

  @@unique([brandId, email])
  @@index([brandId, shopifyCustomerId])
}

enum ReferralStatus {
  CLAIMED
  CONVERTED
  REJECTED_SELF
  REJECTED_EXISTING
  REJECTED_FRAUD
  EXPIRED
}

model Referral {
  id            String         @id @default(cuid())
  brandId       String
  brand         Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  referrerId    String
  referrer      Referrer       @relation(fields: [referrerId], references: [id], onDelete: Cascade)
  friendEmail   String
  refereeCodeId String?
  refereeCode   String?
  status        ReferralStatus @default(CLAIMED)
  orderId       String?
  ipHash        String?
  userAgent     String?
  createdAt     DateTime       @default(now())
  convertedAt   DateTime?
  reward        Reward?

  @@unique([brandId, friendEmail])
  @@index([brandId, status])
}

model Reward {
  id            String   @id @default(cuid())
  referrerId    String
  referrer      Referrer @relation(fields: [referrerId], references: [id], onDelete: Cascade)
  referralId    String   @unique
  referral      Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)
  shopifyCodeId String
  code          String
  emailedAt     DateTime?
  createdAt     DateTime @default(now())
}

model ProcessedWebhook {
  id        String   @id
  topic     String
  shop      String
  createdAt DateTime @default(now())
}
